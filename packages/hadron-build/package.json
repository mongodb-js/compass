{
  "name": "hadron-build",
  "description": "Tooling for Hadron apps like Compass",
  "version": "25.9.6",
  "main": "dist/index.js",
  "compass:main": "src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "bootstrap": "npm run compile",
    "compile": "tsc -p tsconfig-build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "eslint": "eslint-compass",
    "prettier": "prettier-compass",
    "lint": "npm run eslint . && npm run prettier -- --check .",
    "depcheck": "depcheck",
    "check": "npm run typecheck && npm run lint && npm run depcheck",
    "check-ci": "npm run check",
    "test": "mocha",
    "test-cov": "nyc --compact=false --produce-source-map=false -x \"**/*.spec.*\" --reporter=lcov --reporter=text --reporter=html npm run test",
    "test-watch": "npm run test -- --watch",
    "test-ci": "npm run test-cov",
    "reformat": "npm run eslint . -- --fix && npm run prettier -- --write .",
    "postinstall": "node signtool/install.js"
  },
  "bin": {
    "hadron-build": "dist/cli.js"
  },
  "homepage": "https://github.com/mongodb-js/compass",
  "repository": {
    "type": "git",
    "url": "https://github.com/mongodb-js/compass.git"
  },
  "dependencies": {
    "@electron/rebuild": "^4.0.4",
    "@mongodb-js/devtools-github-repo": "^1.4.1",
    "@mongodb-js/dl-center": "^1.6.8",
    "@mongodb-js/electron-wix-msi": "^3.0.0",
    "@mongodb-js/signing-utils": "^0.5.8",
    "@npmcli/arborist": "^6.2.0",
    "@octokit/rest": "^18.6.2",
    "asar": "^3.0.3",
    "chalk": "^4.1.2",
    "cli-table": "^0.3.1",
    "debug": "^4.3.4",
    "del": "^2.0.2",
    "download": "^8.0.0",
    "electron": "^37.10.3",
    "electron-packager": "^15.5.1",
    "electron-packager-plugin-non-proprietary-codecs-ffmpeg": "^1.0.2",
    "flatnest": "^1.0.0",
    "fs-extra": "^8.1.0",
    "getos": "^3.1.4",
    "got": "^10.7.0",
    "in-publish": "^2.0.0",
    "js-yaml": "^4.1.1",
    "json-diff": "^0.10.0",
    "jszip": "^3.10.1",
    "lodash": "^4.18.1",
    "moment": "^2.29.4",
    "mongodb-js-cli": "^0.0.3",
    "node-abi": "^4.31.0",
    "normalize-package-data": "^2.3.5",
    "parse-github-repo-url": "^1.3.0",
    "semver": "^7.6.3",
    "tar": "^6.1.15",
    "which": "^2.0.2",
    "xvfb-maybe": "^0.2.1",
    "yargs": "^17.7.2",
    "zip-folder": "^1.0.0"
  },
  "devDependencies": {
    "@mongodb-js/eslint-config-compass": "^1.4.22",
    "@mongodb-js/mocha-config-compass": "^1.8.0",
    "@mongodb-js/prettier-config-compass": "^1.2.9",
    "@mongodb-js/tsconfig-compass": "^1.3.0",
    "@types/chai": "^4.2.21",
    "@types/debug": "^4.1.12",
    "@types/fs-extra": "^9.0.11",
    "@types/js-yaml": "^4.0.5",
    "@types/lodash": "^4.14.188",
    "@types/mocha": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.3.13",
    "@types/sinon-chai": "^3.2.5",
    "@types/which": "^2.0.2",
    "@types/yargs": "^17.0.33",
    "chai": "^4.2.0",
    "depcheck": "^1.4.1",
    "mocha": "^10.2.0",
    "nyc": "^15.1.0",
    "plist": "^3.0.1",
    "sinon": "^9.0.0",
    "sinon-chai": "^3.7.0",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "electron-installer-debian": "^3.2.0",
    "electron-installer-dmg": "^5.0.1",
    "electron-installer-redhat": "^2.0.0",
    "electron-winstaller": "^5.1.0"
  },
  "license": "SSPL",
  "bugs": {
    "url": "https://jira.mongodb.org/projects/COMPASS/issues",
    "email": "compass@mongodb.com"
  },
  "private": true
}
