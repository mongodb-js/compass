{
  "name": "@mongodb-js/compass-home",
  "description": "Home",
  "private": true,
  "version": "7.1.0",
  "main": "dist/index.js",
  "compass:main": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "compass:exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "prettier": "prettier",
    "test": "mocha",
    "test-electron": "xvfb-maybe electron-mocha \"./src/**/*.spec.tsx\" --no-sandbox",
    "check": "npm run lint && npm run depcheck",
    "eslint": "eslint",
    "lint": "npm run eslint . && npm run prettier -- --check .",
    "depcheck": "compass-scripts check-peer-deps && depcheck",
    "test-cov": "nyc --compact=false --produce-source-map=false -x \"**/*.spec.*\" --reporter=lcov --reporter=text --reporter=html npm run test",
    "test-ci": "npm run test-cov",
    "test-ci-electron": "npm run test-electron",
    "bootstrap": "npm run compile",
    "reformat": "npm run eslint . -- --fix && npm run prettier -- --write ."
  },
  "license": "SSPL",
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "@mongodb-js/atlas-service": "^0.16.0",
    "@mongodb-js/compass-aggregations": "^9.27.0",
    "@mongodb-js/compass-app-stores": "^7.11.0",
    "@mongodb-js/compass-collection": "^4.24.0",
    "@mongodb-js/compass-components": "^1.23.0",
    "@mongodb-js/compass-connections": "^1.26.0",
    "@mongodb-js/compass-crud": "^13.25.0",
    "@mongodb-js/compass-databases-collections": "^1.24.0",
    "@mongodb-js/compass-explain-plan": "^6.25.0",
    "@mongodb-js/compass-export-to-language": "^9.1.0",
    "@mongodb-js/compass-field-store": "^9.0.20",
    "@mongodb-js/compass-find-in-page": "^4.23.0",
    "@mongodb-js/compass-import-export": "^7.24.0",
    "@mongodb-js/compass-indexes": "^5.24.0",
    "@mongodb-js/compass-logging": "^1.2.15",
    "@mongodb-js/compass-query-bar": "^8.26.0",
    "@mongodb-js/compass-saved-aggregations-queries": "^1.25.0",
    "@mongodb-js/compass-schema": "^6.26.0",
    "@mongodb-js/compass-schema-validation": "^6.25.0",
    "@mongodb-js/compass-serverstats": "^16.24.0",
    "@mongodb-js/compass-settings": "^0.27.0",
    "@mongodb-js/compass-shell": "^3.24.0",
    "@mongodb-js/compass-sidebar": "^5.25.0",
    "@mongodb-js/compass-welcome": "^0.23.0",
    "@mongodb-js/compass-workspaces": "^0.6.0",
    "@mongodb-js/connection-info": "^0.2.0",
    "@mongodb-js/connection-storage": "^0.9.0",
    "hadron-app-registry": "^9.1.9",
    "hadron-ipc": "^3.2.13",
    "mongodb": "^6.5.0",
    "mongodb-build-info": "^1.7.0",
    "mongodb-cloud-info": "^2.1.1",
    "mongodb-connection-string-url": "^2.6.0",
    "mongodb-data-service": "^22.19.0",
    "mongodb-ns": "^2.4.0",
    "react": "^17.0.2",
    "resolve-mongodb-srv": "^1.1.2"
  },
  "devDependencies": {
    "@mongodb-js/eslint-config-compass": "^1.1.0",
    "@mongodb-js/mocha-config-compass": "^1.3.8",
    "@mongodb-js/my-queries-storage": "^0.6.0",
    "@mongodb-js/prettier-config-compass": "^1.0.1",
    "@mongodb-js/tsconfig-compass": "^1.0.3",
    "@testing-library/react": "^12.1.4",
    "@testing-library/user-event": "^13.5.0",
    "@types/chai": "^4.2.21",
    "chai": "^4.1.2",
    "compass-preferences-model": "^2.19.0",
    "depcheck": "^1.4.1",
    "electron-mocha": "^12.2.0",
    "eslint": "^7.25.0",
    "eventemitter3": "^4.0.0",
    "mocha": "^10.2.0",
    "nyc": "^15.1.0",
    "prettier": "^2.7.1",
    "react-dom": "^17.0.2",
    "resolve": "^1.15.1",
    "sinon": "^8.1.1",
    "typescript": "^5.0.4",
    "xvfb-maybe": "^0.2.1"
  },
  "homepage": "https://github.com/mongodb-js/compass",
  "bugs": {
    "url": "https://jira.mongodb.org/projects/COMPASS/issues",
    "email": "compass@mongodb.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mongodb-js/compass.git"
  },
  "is_compass_plugin": true
}
