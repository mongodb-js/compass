{
  "name": "@mongodb-js/compass-aggregations",
  "description": "Compass Aggregation Pipeline Builder",
  "private": true,
  "version": "10.0.0",
  "main": "dist/index.js",
  "compass:main": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "compass:exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "bootstrap": "npm run compile",
    "compile": "tsc -p tsconfig-build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "depcheck": "compass-scripts check-peer-deps && depcheck",
    "eslint": "eslint-compass",
    "lint": "npm run eslint . && npm run prettier -- --check .",
    "check": "npm run typecheck && npm run lint && npm run depcheck",
    "check-ci": "npm run check",
    "test": "mocha",
    "test-electron": "xvfb-maybe electron-mocha --no-sandbox",
    "test-cov": "nyc --compact=false --produce-source-map=false -x \"**/*.spec.*\" --reporter=lcov --reporter=text --reporter=html npm run test",
    "test-watch": "npm run test -- --watch",
    "test-ci": "npm run test-cov",
    "test-ci-electron": "npm run test-electron",
    "prettier": "prettier-compass",
    "reformat": "npm run eslint . -- --fix && npm run prettier -- --write ."
  },
  "license": "SSPL",
  "devDependencies": {
    "@mongodb-js/eslint-config-compass": "^1.4.23",
    "@mongodb-js/mocha-config-compass": "^1.8.0",
    "@mongodb-js/prettier-config-compass": "^1.2.9",
    "@mongodb-js/testing-library-compass": "^1.5.7",
    "@mongodb-js/tsconfig-compass": "^1.3.0",
    "@types/babel__generator": "^7.6.8",
    "@types/lodash": "^4.14.188",
    "@types/semver": "^7.3.9",
    "chai": "^4.3.6",
    "depcheck": "^1.4.1",
    "electron-mocha": "^12.2.0",
    "mocha": "^10.2.0",
    "nyc": "^15.1.0",
    "react-dom": "^17.0.2",
    "sinon": "^9.2.3",
    "typescript": "^5.9.3",
    "xvfb-maybe": "^0.2.1"
  },
  "dependencies": {
    "@babel/generator": "^7.19.5",
    "@babel/parser": "^7.19.4",
    "@babel/types": "^7.19.4",
    "@dnd-kit/core": "^6.0.7",
    "@dnd-kit/sortable": "^7.0.2",
    "@dnd-kit/utilities": "^3.2.1",
    "@mongodb-js/atlas-service": "^1.0.0",
    "@mongodb-js/compass-app-registry": "^9.12.0",
    "@mongodb-js/compass-app-stores": "^8.0.0",
    "@mongodb-js/compass-assistant": "^2.0.0",
    "@mongodb-js/compass-collection": "^5.0.0",
    "@mongodb-js/compass-components": "^1.67.0",
    "@mongodb-js/compass-connections": "^2.0.0",
    "@mongodb-js/compass-crud": "^14.0.0",
    "@mongodb-js/compass-editor": "^0.69.0",
    "@mongodb-js/compass-field-store": "^10.0.0",
    "@mongodb-js/compass-generative-ai": "^1.0.0",
    "@mongodb-js/compass-logging": "^1.15.0",
    "@mongodb-js/compass-telemetry": "^1.30.0",
    "@mongodb-js/compass-utils": "^0.10.0",
    "@mongodb-js/compass-workspaces": "^1.0.0",
    "@mongodb-js/explain-plan-helper": "^1.5.11",
    "@mongodb-js/mongodb-constants": "^0.26.0",
    "@mongodb-js/my-queries-storage": "^1.0.0",
    "@mongodb-js/shell-bson-parser": "^1.5.13",
    "bson": "^7.2.0",
    "compass-preferences-model": "^3.0.0",
    "hadron-document": "^8.11.6",
    "hadron-type-checker": "^7.5.6",
    "lodash": "^4.18.1",
    "mongodb": "^7.1.1",
    "mongodb-collection-model": "^5.41.0",
    "mongodb-data-service": "^22.40.0",
    "mongodb-database-model": "^2.41.0",
    "mongodb-instance-model": "^13.0.0",
    "mongodb-ns": "^3.2.0",
    "mongodb-query-parser": "^4.7.13",
    "mongodb-schema": "^12.6.3",
    "re-resizable": "^6.9.0",
    "react": "^17.0.2",
    "react-redux": "^8.1.3",
    "redux": "^4.2.1",
    "redux-thunk": "^2.4.2",
    "semver": "^7.6.3"
  },
  "homepage": "https://github.com/mongodb-js/compass",
  "bugs": {
    "url": "https://jira.mongodb.org/projects/COMPASS/issues",
    "email": "compass@mongodb.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mongodb-js/compass.git"
  },
  "is_compass_plugin": true
}
