{
  "name": "@mongodb-js/compass-mcp-server",
  "description": "Hosts a local MCP server inside Compass so external AI clients can query MongoDB via the user's saved connections",
  "author": {
    "name": "MongoDB Inc",
    "email": "compass@mongodb.com"
  },
  "private": true,
  "bugs": {
    "url": "https://jira.mongodb.org/projects/COMPASS/issues",
    "email": "compass@mongodb.com"
  },
  "homepage": "https://github.com/mongodb-js/compass",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mongodb-js/compass.git"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "license": "SSPL",
  "main": "dist/index.js",
  "compass:main": "src/index.ts",
  "exports": {
    ".": "./dist/index.js",
    "./stdio-bridge": "./dist/stdio-bridge.js"
  },
  "compass:exports": {
    ".": "./src/index.ts",
    "./stdio-bridge": "./src/stdio-bridge.ts"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "bootstrap": "npm run compile",
    "prepublishOnly": "npm run compile && compass-scripts check-exports-exist",
    "compile": "tsc -p tsconfig-build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "eslint": "eslint-compass",
    "prettier": "prettier-compass",
    "lint": "npm run eslint . && npm run prettier -- --check .",
    "depcheck": "compass-scripts check-peer-deps && depcheck",
    "check": "npm run typecheck && npm run lint && npm run depcheck",
    "check-ci": "npm run check",
    "test": "mocha",
    "test-cov": "nyc --compact=false --produce-source-map=false -x \"**/*.spec.*\" --reporter=lcov --reporter=text --reporter=html npm run test",
    "test-watch": "npm run test -- --watch",
    "test-ci": "npm run test-cov",
    "reformat": "npm run eslint . -- --fix && npm run prettier -- --write ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mongodb-js/compass-logging": "^1.14.1",
    "@mongodb-js/connection-info": "^0.27.4",
    "@mongosh/service-provider-node-driver": "^5.0.8",
    "compass-preferences-model": "^2.76.1",
    "electron": "^37.10.3",
    "hadron-ipc": "^3.5.32",
    "jsonc-parser": "^3.2.0",
    "mongodb-build-info": "^1.8.1",
    "mongodb-connection-string-url": "^7.0.1",
    "mongodb-mcp-server": "^1.10.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@mongodb-js/eslint-config-compass": "^1.4.22",
    "@mongodb-js/mocha-config-compass": "^1.8.0",
    "@mongodb-js/prettier-config-compass": "^1.2.9",
    "@mongodb-js/tsconfig-compass": "^1.3.0",
    "@types/chai": "^4.2.21",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.6",
    "depcheck": "^1.4.1",
    "mocha": "^10.2.0",
    "nyc": "^15.1.0",
    "sinon": "^9.2.3",
    "typescript": "^5.9.3"
  }
}
